{
  "name": "youtube-clipper",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/setup.js",
    "setup": "node scripts/setup.js",
    "dev": "concurrently -k -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "start": "concurrently -k -n web,server -c cyan,magenta \"npm:preview\" \"npm:dev:server\""
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "framer-motion": "^12.42.2",
    "postcss": "^8.5.16",
    "react": "^18.3.1",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "youtube-dl-exec": "^3.0.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0"
  }
}
